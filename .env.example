# SW Design System — Figma REST API 환경변수
# 실제 값은 절대 커밋하지 않는다.
# 사용: cp .env.example .env  → .env에 실제 값 입력

# Figma 파일 키 (URL에서 확인: figma.com/design/{FILE_KEY}/...)
FIGMA_FILE_KEY=

# Figma Personal Access Token
# Figma 계정 → Settings → Personal access tokens → 생성
# 필요 권한: Variables (Read only)
FIGMA_TOKEN=
