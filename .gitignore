.DS_Store
**/.DS_Store

# Claude harness — 워크플로우 정의(agents/skills/docs)만 공유, 나머지는 로컬 전용
.claude/*
!.claude/agents/
!.claude/skills/
!.claude/docs/

# 환경변수 — 절대 커밋하지 않음
.env
.env.local

# Figma Variables 수집 결과 — PAT 정보 포함 가능, 커밋하지 않음
registry/figma/figma-variable-metadata.local.json

# npm
node_modules/

# Figma plugin build output
plugins/*/dist/

# Builder preview — 생성 산출물(컨택트시트), 소스(render.js)만 커밋
reports/component-preview/

# Figma MCP raw metadata dump (스냅샷 재생성용 원천 캐시, 비커밋)
data/.figma-raw-metadata.json
